{
  "name": "ticket-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clean": "rm -rf .next && next dev --webpack",
    "dev:fullclean": "rm -rf .next ../.next && next dev --webpack --port 3000",
    "dev:turbo": "next dev",
    "reset:firebase": "node scripts/reset-firebase-data.mjs",
    "sync:demo-auth-passwords": "node scripts/sync-demo-auth-passwords.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify": "pnpm -s lint && pnpm -s exec tsc --noEmit && pnpm -s exec next build --webpack"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.25.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
